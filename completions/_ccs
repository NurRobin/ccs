#compdef ccs
# zsh completion for ccs — Claude Code Session manager

_ccs_sessions() {
    local -a sessions
    sessions=(${(f)"$(tmux -L "${CCS_SOCKET:-ccs}" list-sessions -F '#{session_name}' 2>/dev/null)"})
    [[ -n "$sessions" ]] && _describe 'session' sessions
}

_ccs_schedule_names() {
    local data_dir="${CCS_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/ccs}"
    local -a names
    names=(${(f)"$(awk -F'|' '{print $1}' "$data_dir/schedules.meta" 2>/dev/null)"})
    [[ -n "$names" ]] && _describe 'schedule' names
}

_ccs() {
    local -a commands=(
        'new:Start a new Claude Code session'
        'n:Start a new Claude Code session'
        'ls:List all active sessions'
        'list:List all active sessions'
        'a:Attach to a session'
        'attach:Attach to a session'
        'kill:Kill a session'
        'gc:Clean up orphaned metadata'
        'schedule:Manage scheduled jobs'
        'log:Show cron execution log'
        'help:Show help'
    )

    _arguments -C \
        '(- *)--version[Print version]' \
        '(- *)--help[Show help]' \
        '(- *)-v[Print version]' \
        '(- *)-h[Show help]' \
        '1:command:->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                a|attach|kill)
                    _ccs_sessions
                    ;;
                schedule)
                    if (( CURRENT == 2 )); then
                        local -a schedule_commands=(
                            'add:Create a new scheduled job'
                            'ls:List scheduled jobs'
                            'rm:Remove a scheduled job'
                            'log:Show cron log'
                        )
                        _describe 'schedule command' schedule_commands
                    elif [[ $words[2] == "rm" ]] && (( CURRENT == 3 )); then
                        _ccs_schedule_names
                    fi
                    ;;
            esac
            ;;
    esac
}

_ccs
